#!/bin/bash
#       _                 _                      
#   ___| | ___  _   _  __| |___ _   _ _ __   ___ 
#  / __| |/ _ \| | | |/ _` / __| | | | '_ \ / __|
# | (__| | (_) | |_| | (_| \__ \ |_| | | | | (__ 
#  \___|_|\___/ \__,_|\__,_|___/\__, |_| |_|\___|
#                               |___/            
# cloudsync - Dynamic & Verbose Cloud File Manager using rclone
#
# Projects: https://github.com/galaxy-cli/cloudsync

# --- INITIALIZATION ---
SELECTED_REMOTES=()
SOURCE_PATH="" 
DEST_PATH=""
SELECTED_ACTION=""
VERBOSE=false
DRY_RUN=false

# --- FUNCTIONS ---
show_help() {
    cat << EOF
DESCRIPTION
A multi-remote wrapper for rclone.

USAGE 
  cloudsync [ACTION] -c "remote1,remote2" [OPTIONS]

ACTIONS (Choose one)
  --sync             Mirror source to destination (DELETES extra files on remote)
  --copy             Copy source to destination (keeps existing files on remote)
  --remove           Delete a specific file from remotes
  --remove-dir       Delete an entire directory (purge) from remotes
  --make-dir         Create a new directory on remotes
  -l, --list         List contents of the remote path

REQUIRED PARAMETERS
  -c, --cloud        Remotes to target (comma-separated: "drive,dropbox")
  -p, --path         Local source path (required for --sync/--copy)
  -d, --dest         Remote destination path (e.g., "Backups/Work")

FLAGS
  -n, --dry-run      Simulate the action without making changes
  -v, --verbose      Print the underlying rclone commands
  -h, --help         Show this menu

EXAMPLES
  cloudsync --sync -c "mega,gdrive" -p ~/Documents -d "CloudBackups"
  cloudsync --remove-dir -n -c "dropbox" -d "OldFiles"
EOF
}

check_rclone() {
    if ! command -v rclone &> /dev/null; then
        echo "rclone not found. Installing..."
        curl https://rclone.org | sudo bash
        sudo rclone selfupdate --beta
    fi
}

log_info() {
    if [ "$VERBOSE" = true ]; then
        echo -e "\033[1;33m[INFO]:\033[0m $1"
    fi
}

execute_action() {
    local action=$1
    local dry_flag=""
    [ "$DRY_RUN" = true ] && dry_flag="--dry-run"
    
    local configured_remotes
    configured_remotes=$(rclone listremotes)

    for remote in "${SELECTED_REMOTES[@]}"; do
        remote=$(echo "$remote" | xargs)

        if [[ ! "$configured_remotes" =~ ^$remote: ]]; then
            echo -e "\033[1;31m[SKIP]\033[0m Remote '$remote' not configured in rclone"
            continue
        fi

        [ "$DRY_RUN" = true ] && echo -e "\033[1;35m[DRY-RUN MODE ACTIVE]\033[0m Targeting: $remote"

        case "$action" in
            "sync"|"copy")
                log_info "rclone $action \"$SOURCE_PATH\" \"$remote:$DEST_PATH\" $dry_flag"
                rclone "$action" "$SOURCE_PATH" "$remote:$DEST_PATH" --progress $dry_flag
                ;;
            "remove")
                log_info "rclone deletefile \"$remote:$DEST_PATH\" $dry_flag"
                rclone deletefile "$remote:$DEST_PATH" $dry_flag
                ;;
            "remove-dir")
                log_info "rclone purge \"$remote:$DEST_PATH\" $dry_flag"
                rclone purge "$remote:$DEST_PATH" $dry_flag
                ;;
            "make-dir")
                log_info "rclone mkdir \"$remote:$DEST_PATH\" $dry_flag"
                rclone mkdir "$remote:$DEST_PATH" $dry_flag
                ;;
            "list")
                echo -e "\033[1;36m--- $remote ($DEST_PATH) ---\033[0m"
                rclone ls "$remote:$DEST_PATH"
                ;;
        esac
    done
}

# --- ARGUMENT PARSING ---
if [[ $# -eq 0 ]]; then
    show_help
    exit 0
fi

while [[ $# -gt 0 ]]; do
    case "$1" in
        --sync|--copy|--remove|--remove-dir|--make-dir) SELECTED_ACTION="${1#--}"; shift ;;
        -l|--list)    SELECTED_ACTION="list"; shift ;;
        -p|--path)    SOURCE_PATH="$2"; shift 2 ;;
        -d|--dest)    DEST_PATH="$2"; shift 2 ;;
        -v|--verbose) VERBOSE=true; shift ;;
        -n|--dry-run) DRY_RUN=true; shift ;;
        -c|--cloud)   IFS=',' read -ra SELECTED_REMOTES <<< "$2"; shift 2 ;;
        -h|--help)    show_help; exit 0 ;;
        *) echo "Invalid option: $1"; show_help; exit 1 ;;
    esac
done

# --- VALIDATION ---
[[ -z "$SELECTED_ACTION" ]] && { echo "ERROR - No action specified"; show_help; exit 1; }
[[ ${#SELECTED_REMOTES[@]} -eq 0 ]] && { echo "ERROR - Specify at least one remote using -c"; exit 1; }

case "$SELECTED_ACTION" in
    sync|copy)
        [[ -z "$SOURCE_PATH" ]] && { echo "ERROR - --$SELECTED_ACTION requires a source path (-p)"; exit 1; }
        [[ ! -e "$SOURCE_PATH" ]] && { echo "ERROR: Source path '$SOURCE_PATH' does not exist"; exit 1; }
        [[ -z "$DEST_PATH" ]]   && { echo "ERROR - --$SELECTED_ACTION requires a destination path (-d)"; exit 1; }
        ;;
    remove|remove-dir|make-dir|list)
        [[ -z "$DEST_PATH" ]]   && { echo "ERROR - --$SELECTED_ACTION requires a destination path (-d)"; exit 1; }
        ;;
esac

# --- EXECUTION ---
check_rclone
execute_action "$SELECTED_ACTION"

echo -e "\n\033[1;32m✔ Task '$SELECTED_ACTION' finished\033[0m"